PORT=1337
NODE_ENV=production
KONGA_HOOK_TIMEOUT=120000
DB_ADAPTER=postgres
DB_URI=postgresql://localhost:5432/konga

# Standby database for HA failover (optional)
# If primary DB is unreachable, Konga will auto-switch to standby
# DB_STANDBY_URI=postgresql://user:pass@standby-host:5432/konga

# Connection timeout for failover detection (ms, default 5000)
# DB_FAILOVER_TIMEOUT=5000

KONGA_LOG_LEVEL=warn
TOKEN_SECRET=some_secret_token
